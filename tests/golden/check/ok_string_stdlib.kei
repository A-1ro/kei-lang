module string.stdlib

func greet(name: String, suffix: String) -> String {
  return name + suffix
}

func nameLength(name: String) -> Int {
  return name.length
}

func describe(n: Int) -> String {
  return "value=" + n.toString()
}

func parseOrZero(s: String) -> Int {
  return match s.toInt() {
    Some(n) => n
    None => 0
  }
}

func csvFirst(row: String) -> String {
  let parts = row.split(",")
  return match parts.get(0) {
    Some(p) => p
    None => ""
  }
}

func findAt(s: String, needle: String) -> Int {
  return match s.indexOf(needle) {
    Some(pos) => pos
    None => -1
  }
}
