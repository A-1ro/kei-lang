{
  "name": "kei-examples-workers-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kei v0.9 M42 Workers テンプレート: Cloudflare Workers 上に Hono + @kei/hono で Kei ハンドラを載せる最小テンプレート(在庫 API を実演)。",
  "scripts": {
    "kei:build": "cargo run -q -p kei_cli --bin kei -- build . --out-dir dist",
    "pretypecheck": "bash scripts/ensure-deps-built.sh",
    "typecheck": "tsc --noEmit",
    "predry-run": "bash scripts/ensure-deps-built.sh",
    "dry-run": "wrangler deploy --dry-run --outdir dist-wrangler",
    "predev": "bash scripts/ensure-deps-built.sh",
    "dev": "wrangler dev",
    "pretest": "bash scripts/ensure-deps-built.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@kei/runtime": "file:../../runtime",
    "@kei/hono": "file:../../tests/cli/packages/kei-hono",
    "hono": "^4.9.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.0.0"
  }
}
